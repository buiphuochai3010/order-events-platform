# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
!.env.example

# AI tool config (local, không chia sẻ qua git)
.qodo/

# Editor/IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Node / Next.js frontend
frontend/node_modules/
frontend/.next/
frontend/out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker / K8s local state
infra/postgres-data/
infra/kafka-data/
infra/redis-data/
*.kubeconfig
kubeconfig*.yaml

# Secrets (không commit key/cert thật)
*.pem
*.key
secrets.yaml
